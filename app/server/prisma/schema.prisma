generator client {
  provider = "prisma-client-js"
}

model User{
  id          Int       @id @default(autoincrement())
  name        String?
  email       String    @unique
  avatar      String    @default("")
  createdAt   DateTime  @default(now())
}
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
